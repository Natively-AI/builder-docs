{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Native.Builder Docs",
  "description": "Native.Builder is a software factory — specialized AI agents that build and ship products so you save time and money.",
  "colors": {
    "primary": "#7C54FF",
    "light": "#4366FF",
    "dark": "#111827"
  },
  "favicon": "/logo/icon.png",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        },
        {
          "anchor": "Changelog",
          "icon": "scroll-text",
          "href": "/changelog"
        },
        {
          "anchor": "Support",
          "icon": "life-buoy",
          "href": "/support"
        }
      ]
    },
    "groups": [
      {
        "group": "Introduction",
        "icon": "sparkles",
        "pages": [
          "introduction/welcome",
          "introduction/getting-started",
          "introduction/plans-and-credits",
          "introduction/faq"
        ]
      },
      {
        "group": "Features",
        "icon": "layers",
        "pages": [
          "features/publish",
          "features/custom-domain",
          "features/workspaces",
          "features/prompting"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Pricing",
        "href": "/introduction/plans-and-credits"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open app",
      "href": "https://beta.nativelyai.com"
    }
  },
  "footer": {
    "socials": {
      "discord": "https://discord.gg/uP2TQVtkRj",
      "linkedin": "https://linkedin.com/company/natively-ai"
    }
